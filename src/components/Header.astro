---
const navLinks = [
  { href: '/articles', label: 'Reviews' },
  { href: '/about', label: 'About' },
];
---
<header class="site-header">
  <div class="container">
    <a href="/" class="logo">
      <img src="/formxgolf-logo.svg" alt="FormX Golf" class="logo-img" />
    </a>
    <nav>
      {navLinks.map(link => (
        <a href={link.href} class="nav-link">{link.label}</a>
      ))}
    </nav>
  </div>
</header>

<style>
  .site-header {
    background: #fff;
    border-bottom: 2px solid #1B5E20;
    position: sticky;
    top: 0;
    z-index: 100;
  }
  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
  }
  .logo {
    display: flex;
    align-items: center;
    text-decoration: none;
  }
  .logo-img {
    height: 48px;
    width: 48px;
    display: block;
  }
  nav { display: flex; gap: 2rem; }
  .nav-link {
    text-decoration: none;
    color: #333;
    font-weight: 600;
    font-size: 0.95rem;
    transition: color 0.2s;
  }
  .nav-link:hover { color: #1B5E20; }
</style>
