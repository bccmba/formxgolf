---
interface Props {
  title: string;
  description: string;
  slug: string;
  category: string;
  pubDate: Date;
  featured?: boolean;
}
const { title, description, slug, category, pubDate, featured = false } = Astro.props;
const formattedDate = pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
---
<a href={`/articles/${slug}`} class={`card ${featured ? 'card--featured' : ''}`}>
  <div class="card-category">{category}</div>
  <h2 class="card-title">{title}</h2>
  <p class="card-desc">{description}</p>
  <div class="card-meta">
    <span class="card-date">{formattedDate}</span>
    <span class="card-cta">Read review →</span>
  </div>
</a>

<style>
  .card {
    display: block;
    background: #fff;
    border: 1px solid #e8e8e8;
    border-radius: 10px;
    padding: 1.75rem;
    text-decoration: none;
    color: inherit;
    transition: transform 0.2s, box-shadow 0.2s, border-color 0.2s;
  }
  .card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 30px rgba(0,0,0,0.08);
    border-color: #1B5E20;
  }
  .card--featured {
    border-left: 4px solid #1B5E20;
  }
  .card-category {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: #1B5E20;
    margin-bottom: 0.6rem;
  }
  .card-title {
    font-size: 1.15rem;
    font-weight: 700;
    color: #111;
    margin: 0 0 0.6rem;
    line-height: 1.4;
  }
  .card-desc {
    font-size: 0.9rem;
    color: #555;
    line-height: 1.6;
    margin: 0 0 1.25rem;
  }
  .card-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .card-date { font-size: 0.8rem; color: #999; }
  .card-cta { font-size: 0.85rem; font-weight: 600; color: #1B5E20; }
</style>
