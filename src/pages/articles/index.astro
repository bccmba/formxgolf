---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('articles');
const sorted = allArticles.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const categories = [...new Set(sorted.map(a => a.data.category))];
---
<BaseLayout title="All Reviews" description="All golf tech and gear reviews on FormX Golf — GPS watches, rangefinders, launch monitors, and simulator setups.">
  <Header slot="header" />

  <section class="page-header">
    <div class="container">
      <h1>All Reviews</h1>
      <p>Every review we've published, newest first.</p>
    </div>
  </section>

  <section class="articles-page">
    <div class="container">
      <div class="filter-bar">
        <span class="filter-label">Filter by:</span>
        <a href="/articles" class="filter-chip filter-chip--active">All</a>
        {categories.map(cat => (
          <a href={`/articles?category=${encodeURIComponent(cat)}`} class="filter-chip">{cat}</a>
        ))}
      </div>

      <div class="articles-grid">
        {sorted.map(article => (
          <ArticleCard
            title={article.data.title}
            description={article.data.description}
            slug={article.slug}
            category={article.data.category}
            pubDate={article.data.pubDate}
            featured={article.data.featured}
          />
        ))}
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>

<style>
  .page-header { background: #1B5E20; padding: 3rem 0; color: #fff; }
  .page-header h1 { font-size: 2.2rem; font-weight: 800; margin-bottom: 0.5rem; }
  .page-header p { opacity: 0.8; font-size: 1.05rem; }
  .container { max-width: 1100px; margin: 0 auto; padding: 0 1.5rem; }
  .articles-page { padding: 3rem 0; }
  .filter-bar { display: flex; align-items: center; gap: 0.6rem; flex-wrap: wrap; margin-bottom: 2rem; }
  .filter-label { font-size: 0.85rem; font-weight: 600; color: #777; }
  .filter-chip {
    display: inline-block;
    padding: 0.3rem 0.9rem;
    border: 1.5px solid #ddd;
    border-radius: 20px;
    font-size: 0.82rem;
    font-weight: 600;
    color: #555;
    text-decoration: none;
    transition: all 0.2s;
  }
  .filter-chip:hover, .filter-chip--active {
    background: #1B5E20;
    border-color: #1B5E20;
    color: #fff;
  }
  .articles-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem; }
  @media (max-width: 900px) { .articles-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 600px) { .articles-grid { grid-template-columns: 1fr; } }
</style>
