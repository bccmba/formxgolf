---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const articles = await getCollection('articles');
const sortedArticles = articles.sort((a, b) =>
  new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime()
);

const courses = [
  {
    name: "Augusta National",
    location: "Augusta, Georgia",
    description: "Home of The Masters, considered the most prestigious golf tournament in the world. Azaleas, Amen Corner, and unforgettable history.",
    image: "https://images.unsplash.com/photo-1742498626081-a64f9677f468?w=800&q=80&auto=format&fit=crop",
  },
  {
    name: "Pebble Beach Golf Links",
    location: "Pebble Beach, California",
    description: "The most famous public golf course in America, carved into the dramatic California coastline. Every hole a postcard.",
    image: "https://images.unsplash.com/photo-1561066030-f096e3ba23dd?w=800&q=80&auto=format&fit=crop",
  },
  {
    name: "St Andrews Old Course",
    location: "Fife, Scotland",
    description: "The birthplace of golf. Walk the same fairways as legends dating back to 1552. The 18th hole is unlike anything in the world.",
    image: "https://images.unsplash.com/photo-1687291134396-304d837a1d65?w=800&q=80&auto=format&fit=crop",
  },
  {
    name: "Indian Wells Golf Resort",
    location: "Indian Wells, California",
    description: "Two championship desert courses set beneath the Santa Rosa Mountains in Palm Springs. Year-round sunshine and immaculate conditions.",
    image: "https://images.unsplash.com/photo-1671904942522-8e2a0dbb709f?w=800&q=80&auto=format&fit=crop",
  },
];
---

<BaseLayout title="FormX Golf — Golf Gear Reviews, Tips & Tech">
  <!-- Hero Section -->
  <section class="hero">
    <div class="hero-content">
      <h1>Play better golf.<br />Buy smarter gear.</h1>
      <p>
        Independent reviews of launch monitors, simulators, GPS watches, and everything else
        you need to take your game seriously — without the fluff.
      </p>
      <a href="/articles" class="btn-primary">Browse All Reviews</a>
    </div>
  </section>

  <!-- Featured Articles -->
  <section class="articles-section">
    <div class="container">
      <h2>Latest Reviews & Guides</h2>
      <div class="articles-grid">
        {sortedArticles.map((article) => (
          <ArticleCard article={article} />
        ))}
      </div>
    </div>
  </section>

  <!-- Famous Courses Showcase -->
  <section class="courses-section">
    <div class="container">
      <h2>Golf's Greatest Courses</h2>
      <p class="section-subtitle">
        From links to desert to coastline — the courses every golfer dreams of playing.
      </p>
      <div class="courses-grid">
        {courses.map((course) => (
          <div class="course-card">
            <div class="course-image-wrap">
              <img
                src={course.image}
                alt={course.name}
                loading="lazy"
              />
            </div>
            <div class="course-info">
              <h3>{course.name}</h3>
              <span class="course-location">📍 {course.location}</span>
              <p>{course.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Newsletter / CTA -->
  <section class="cta-section">
    <div class="container cta-inner">
      <h2>Get gear picks sent to your inbox</h2>
      <p>No spam. Just honest reviews when we publish something worth reading.</p>
      <a href="mailto:hello@formxgolf.com?subject=Newsletter Signup" class="btn-primary">
        Sign Up Free
      </a>
    </div>
  </section>
</BaseLayout>

<style>
  /* ---- Hero ---- */
  .hero {
    background: linear-gradient(135deg, #1a3a2a 0%, #2d6a4f 60%, #40916c 100%);
    color: white;
    padding: 5rem 1.5rem;
    text-align: center;
  }
  .hero-content {
    max-width: 680px;
    margin: 0 auto;
  }
  .hero h1 {
    font-size: clamp(2rem, 5vw, 3.2rem);
    font-weight: 800;
    line-height: 1.15;
    margin-bottom: 1.25rem;
    letter-spacing: -0.02em;
  }
  .hero p {
    font-size: 1.15rem;
    opacity: 0.9;
    margin-bottom: 2rem;
    line-height: 1.6;
  }
  .btn-primary {
    display: inline-block;
    background: #d4af37;
    color: #1a1a1a;
    padding: 0.8rem 2rem;
    border-radius: 6px;
    font-weight: 700;
    font-size: 1rem;
    text-decoration: none;
    transition: background 0.2s;
  }
  .btn-primary:hover {
    background: #c49a2a;
  }

  /* ---- Shared Container ---- */
  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* ---- Articles ---- */
  .articles-section {
    padding: 4rem 1.5rem;
    background: #f9fafb;
  }
  .articles-section h2,
  .courses-section h2 {
    font-size: 1.8rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
    color: #1a3a2a;
  }
  .articles-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.75rem;
    margin-top: 2rem;
  }

  /* ---- Courses ---- */
  .courses-section {
    padding: 4rem 1.5rem;
    background: #fff;
  }
  .section-subtitle {
    color: #555;
    font-size: 1.05rem;
    margin-bottom: 2.5rem;
    margin-top: 0.25rem;
  }
  .courses-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 1.5rem;
  }
  .course-card {
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
    transition: transform 0.2s, box-shadow 0.2s;
    background: #fff;
  }
  .course-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 6px 24px rgba(0, 0, 0, 0.14);
  }
  .course-image-wrap {
    width: 100%;
    aspect-ratio: 16 / 10;
    overflow: hidden;
  }
  .course-image-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s;
  }
  .course-card:hover .course-image-wrap img {
    transform: scale(1.05);
  }
  .course-info {
    padding: 1.1rem 1.25rem 1.4rem;
  }
  .course-info h3 {
    font-size: 1.05rem;
    font-weight: 700;
    margin: 0 0 0.25rem;
    color: #1a3a2a;
  }
  .course-location {
    font-size: 0.8rem;
    color: #888;
    display: block;
    margin-bottom: 0.6rem;
  }
  .course-info p {
    font-size: 0.875rem;
    color: #444;
    line-height: 1.55;
    margin: 0;
  }

  /* ---- CTA ---- */
  .cta-section {
    background: linear-gradient(135deg, #1a3a2a, #2d6a4f);
    color: white;
    padding: 4rem 1.5rem;
    text-align: center;
  }
  .cta-inner {
    max-width: 600px;
  }
  .cta-section h2 {
    font-size: 1.8rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
  }
  .cta-section p {
    opacity: 0.85;
    margin-bottom: 2rem;
    font-size: 1rem;
  }
</style>
