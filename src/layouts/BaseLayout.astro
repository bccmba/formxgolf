---
interface Props {
  title: string;
  description?: string;
  image?: string;
}
const { title, description = 'Golf tech and gear reviews to help you play better.', image } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | FormX Golf</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={`${title} | FormX Golf`} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    {image && <meta property="og:image" content={image} />}
    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <slot name="header" />
    <main>
      <slot />
    </main>
    <slot name="footer" />
  </body>
</html>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --green-dark: #1B5E20;
    --green-mid: #2E7D32;
    --green-light: #E8F5E9;
    --gold: #F9A825;
    --text-dark: #111;
    --text-mid: #444;
    --text-light: #777;
    --border: #e8e8e8;
    --bg: #fafafa;
    --white: #fff;
    --radius: 10px;
    --max-width: 1100px;
  }

  html { font-size: 16px; scroll-behavior: smooth; }

  body {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', sans-serif;
    background: var(--bg);
    color: var(--text-dark);
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
  }

  .container {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  h1, h2, h3, h4 { line-height: 1.3; }
  img { max-width: 100%; display: block; }
  a { color: var(--green-dark); }

  /* Article prose styles */
  .prose { max-width: 740px; }
  .prose h2 { font-size: 1.5rem; margin: 2.5rem 0 1rem; padding-bottom: 0.5rem; border-bottom: 2px solid var(--green-light); color: var(--green-dark); }
  .prose h3 { font-size: 1.2rem; margin: 2rem 0 0.75rem; color: var(--text-dark); }
  .prose p { margin-bottom: 1.25rem; color: var(--text-mid); font-size: 1.05rem; line-height: 1.8; }
  .prose ul, .prose ol { margin: 1rem 0 1.25rem 1.5rem; color: var(--text-mid); }
  .prose li { margin-bottom: 0.4rem; line-height: 1.7; font-size: 1.05rem; }
  .prose strong { color: var(--text-dark); font-weight: 700; }
  .prose a { color: var(--green-dark); font-weight: 600; }
  .prose a:hover { text-decoration: none; }
  .prose blockquote { border-left: 4px solid var(--green-mid); padding-left: 1.25rem; margin: 1.5rem 0; color: var(--text-mid); font-style: italic; }
  .prose hr { border: none; border-top: 2px solid var(--border); margin: 2.5rem 0; }
  .prose em { color: var(--text-light); font-style: italic; }

  /* Tables */
  .prose table { width: 100%; border-collapse: collapse; margin: 1.5rem 0; font-size: 0.95rem; }
  .prose th { background: var(--green-dark); color: #fff; padding: 0.6rem 1rem; text-align: left; font-weight: 600; }
  .prose td { padding: 0.6rem 1rem; border-bottom: 1px solid var(--border); color: var(--text-mid); }
  .prose tr:nth-child(even) td { background: var(--green-light); }

  @media (max-width: 768px) {
    .prose h2 { font-size: 1.3rem; }
    .prose p, .prose li { font-size: 1rem; }
  }
</style>
