---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  category: string;
}

const { title, description, pubDate, updatedDate, category } = Astro.props;
const formattedDate = pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
const formattedUpdated = updatedDate?.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---
<BaseLayout title={title} description={description}>
  <Header slot="header" />

  <article class="article-wrapper">
    <div class="container">
      <div class="article-header">
        <a href="/articles" class="back-link">← All Reviews</a>
        <div class="article-category">{category}</div>
        <h1 class="article-title">{title}</h1>
        <p class="article-desc">{description}</p>
        <div class="article-meta">
          <time datetime={pubDate.toISOString()}>Published {formattedDate}</time>
          {formattedUpdated && <time datetime={updatedDate!.toISOString()}>Updated {formattedUpdated}</time>}
        </div>
      </div>

      <div class="article-body prose">
        <slot />
      </div>

      <div class="article-footer">
        <a href="/articles" class="btn-secondary">← Back to all reviews</a>
      </div>
    </div>
  </article>

  <Footer slot="footer" />
</BaseLayout>

<style>
  .article-wrapper { padding: 3rem 0 4rem; }
  .container { max-width: 1100px; margin: 0 auto; padding: 0 1.5rem; }
  .back-link {
    display: inline-block;
    color: var(--green-dark);
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 600;
    margin-bottom: 1.5rem;
    opacity: 0.8;
    transition: opacity 0.2s;
  }
  .back-link:hover { opacity: 1; }
  .article-category {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: var(--green-dark);
    margin-bottom: 0.75rem;
  }
  .article-title {
    font-size: clamp(1.8rem, 4vw, 2.5rem);
    font-weight: 800;
    color: var(--text-dark);
    margin-bottom: 0.75rem;
    max-width: 740px;
    line-height: 1.2;
  }
  .article-desc {
    font-size: 1.15rem;
    color: var(--text-light);
    max-width: 740px;
    margin-bottom: 1rem;
    line-height: 1.6;
  }
  .article-meta {
    display: flex;
    gap: 1.5rem;
    font-size: 0.85rem;
    color: var(--text-light);
    padding-bottom: 2rem;
    margin-bottom: 2rem;
    border-bottom: 2px solid var(--border);
    max-width: 740px;
  }
  .article-body { max-width: 740px; }
  .article-footer {
    max-width: 740px;
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 2px solid var(--border);
  }
  .btn-secondary {
    display: inline-block;
    padding: 0.6rem 1.25rem;
    border: 2px solid var(--green-dark);
    border-radius: 6px;
    color: var(--green-dark);
    text-decoration: none;
    font-weight: 600;
    font-size: 0.9rem;
    transition: all 0.2s;
  }
  .btn-secondary:hover { background: var(--green-dark); color: #fff; }
</style>
